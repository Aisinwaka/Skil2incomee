    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "express-rate-limit": "^7.0.0",
    "redis": "^4.6.10",
    "openai": "^4.0.0",
    "axios": "^1.5.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/express": "^4.17.17",
    "typescript": "^5.0.0",
    "ts-node-dev": "^2.0.0",
    "eslint": "^8.48.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
